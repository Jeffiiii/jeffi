{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "components/core/**",
              "ui_kits/elysia-chat/**",
              "ui_kits/personal-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|Zen Kaku Gothic New|DM Mono))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, Zen Kaku Gothic New, DM Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|children|size|ring|speaking|status|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, children, size, ring, speaking, status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|live|away)$/]",
        "message": "<Avatar> status must be one of 'online' | 'live' | 'away'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarStage'] > JSXAttribute > JSXIdentifier[name!=/^(?:poster|emotion|speaking|name|live|height|children|style|key|ref|className|style|children)$/]",
        "message": "<AvatarStage> doesn't accept that prop. Declared props: poster, emotion, speaking, name, live, height, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarStage'] > JSXAttribute[name.name='emotion'] > Literal[value!=/^(?:happy|playful|shy|sad|surprised|neutral)$/]",
        "message": "<AvatarStage> emotion must be one of 'happy' | 'playful' | 'shy' | 'sad' | 'surprised' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|jeffi|lavender|mint|crystal|success|warning|danger|neutral)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'jeffi' | 'lavender' | 'mint' | 'crystal' | 'success' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|hover|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, hover, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:glass|solid|tint|dark|surface)$/]",
        "message": "<Card> tone must be one of 'glass' | 'solid' | 'tint' | 'dark' | 'surface'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|children|name|time|typing|style|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: from, children, name, time, typing, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:elysia|user)$/]",
        "message": "<ChatBubble> from must be one of 'elysia' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatComposer'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onSend|onMic|listening|dark|placeholder|style|key|ref|className|style|children)$/]",
        "message": "<ChatComposer> doesn't accept that prop. Declared props: value, onChange, onSend, onMic, listening, dark, placeholder, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmotionPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:emotion|lang|style|key|ref|className|style|children)$/]",
        "message": "<EmotionPill> doesn't accept that prop. Declared props: emotion, lang, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmotionPill'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:en|zh)$/]",
        "message": "<EmotionPill> lang must be one of 'en' | 'zh'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|variant|size|active|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, variant, size, active, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|glass|ghost|dark)$/]",
        "message": "<IconButton> variant must be one of 'solid' | 'glass' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|icon|dark|style|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: as, icon, dark, style, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|textarea)$/]",
        "message": "<Input> as must be one of 'input' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Live2DStage'] > JSXAttribute > JSXIdentifier[name!=/^(?:modelUrl|emotion|speaking|name|live|height|zoom|yOffset|children|style|key|ref|className|style|children)$/]",
        "message": "<Live2DStage> doesn't accept that prop. Declared props: modelUrl, emotion, speaking, name, live, height, zoom, yOffset, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Live2DStage'] > JSXAttribute[name.name='emotion'] > Literal[value!=/^(?:happy|playful|shy|sad|surprised|neutral|angry)$/]",
        "message": "<Live2DStage> emotion must be one of 'happy' | 'playful' | 'shy' | 'sad' | 'surprised' | 'neutral' | 'angry'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: key, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|dark|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, active, dark, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
